{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["node", "vite/client"]
  },
  "include": [
    "packages/shared/src/**/*",
    "apps/main/src/**/*",
    "apps/preload/src/**/*",
    "apps/renderer/src/**/*",
    "electron.vite.config.ts",
    "eslint.config.js"
  ]
}
